# MiniMesh root environment example
# Copy this to .env — do not commit .env

APP_NAME=MiniMesh
APP_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:5174

# Provider API keys (Phase 14 — Real Provider Integration)
# Leave blank to use mock provider (default)
# Get your Meshy key at: https://app.meshy.ai/account
MESHY_API_KEY=
TRIPO_API_KEY=
RODIN_API_KEY=
